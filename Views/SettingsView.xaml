<UserControl x:Class="ARA.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d"
			 xmlns:enums="clr-namespace:ARA.Enums"
			 xmlns:pages="clr-namespace:ARA.ViewModels.Pages" 
			 xmlns:controls="clr-namespace:ARA.Controls.CustomControls"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008" d:DataContext="{d:DesignInstance Type=pages:SettingsViewModel}">
	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="*" />
			<ColumnDefinition Width="16" />
			<ColumnDefinition Width="*" />
		</Grid.ColumnDefinitions>

		<Grid.RowDefinitions>
			<RowDefinition Height="40" />
			<RowDefinition Height="12" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="4" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
			<RowDefinition Height="40" />
		</Grid.RowDefinitions>

		<TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Style="{StaticResource PageTitle}" Text="{DynamicResource Settings.Title}"/>

		<GroupBox Grid.Row="2" Grid.Column="0"  Header="{DynamicResource Settings.General}" Style="{StaticResource AraGroupBox}">
			<StackPanel Orientation="Vertical">
				<StackPanel Style="{StaticResource AraStackRow}" Orientation="Horizontal">
					<TextBlock Style="{StaticResource AraStackRowLabel}" Text="{DynamicResource Settings.Theme}"/>
					<controls:AraComboBox
					x:Name="ThemesComboBox"
					Style="{StaticResource AraComboBox}"
					ItemsSource="{Binding Themes}"
					SelectedItem="{Binding SelectedTheme, Mode=TwoWay}">
						<controls:AraComboBox.ItemTemplate>
							<DataTemplate>
								<StackPanel Orientation="Horizontal">
									<Image Source="{Binding Path}" Height="32" Stretch="Uniform" VerticalAlignment="Center"/>
									<TextBlock Text="{Binding Name}" VerticalAlignment="Center" Margin="8 0 0 0"/>
								</StackPanel>
							</DataTemplate>
						</controls:AraComboBox.ItemTemplate>
					</controls:AraComboBox>
				</StackPanel>

				<StackPanel Style="{StaticResource AraStackRow}" Orientation="Horizontal">
					<TextBlock Style="{StaticResource AraStackRowLabel}" Text="{DynamicResource Settings.Language}"/>
					<controls:AraComboBox
					x:Name="LanguagesComboBox"
					Style="{StaticResource AraComboBox}"
					ItemsSource="{Binding Locales}"
					SelectedItem="{Binding SelectedLocale, Mode=TwoWay}">
						<controls:AraComboBox.ItemTemplate>
							<DataTemplate>
								<StackPanel Orientation="Horizontal">
									<Image Source="{Binding Path}" Height="32" Stretch="Uniform" VerticalAlignment="Center"/>
									<TextBlock Text="{Binding Name}" VerticalAlignment="Center" Margin="8 0 0 0"/>
								</StackPanel>
							</DataTemplate>
						</controls:AraComboBox.ItemTemplate>
					</controls:AraComboBox>
				</StackPanel>
			</StackPanel>
		</GroupBox>

		<GroupBox Grid.Row="2" Grid.Column="2" Header="{DynamicResource Settings.Advanced}" Style="{StaticResource AraGroupBox}">
			<StackPanel Orientation="Vertical">
				<StackPanel Style="{StaticResource AraStackRow}" Orientation="Horizontal">
					<TextBlock Style="{StaticResource AraStackRowLabel}" TextWrapping="Wrap" Text="{DynamicResource Settings.DebugLevel}"/>
					<controls:AraComboBox
						x:Name="DebugLevelComboBox"
						Style="{StaticResource AraComboBox}"
						ItemsSource="{Binding DebugLevels}"
						SelectedItem="{Binding SelectedDebugLevel, Mode=TwoWay}">
						<controls:AraComboBox.ItemTemplate>
							<DataTemplate>
								<StackPanel Orientation="Horizontal">
									<Image Source="{Binding Path}" Height="32" Stretch="Uniform" VerticalAlignment="Center"/>
									<TextBlock Text="{Binding Name}" VerticalAlignment="Center" Margin="8 0 0 0"/>
								</StackPanel>
							</DataTemplate>
						</controls:AraComboBox.ItemTemplate>
					</controls:AraComboBox>
				</StackPanel>

				<StackPanel Style="{StaticResource AraStackRow}" Orientation="Horizontal">
					<TextBlock Style="{StaticResource AraStackRowLabel}" Text="{DynamicResource Settings.CaptureMode}"/>
					<controls:AraComboBox
						x:Name="CaptureModeComboBox"
						Style="{StaticResource AraComboBox}"
						ItemsSource="{Binding CaptureModes}"
						SelectedItem="{Binding SelectedCaptureMode, Mode=TwoWay}">
						<controls:AraComboBox.ItemTemplate>
							<DataTemplate>
								<StackPanel Orientation="Horizontal">
									<Image Source="{Binding Path}" Height="32" Stretch="Uniform" VerticalAlignment="Center"/>
									<TextBlock Text="{Binding Name}" VerticalAlignment="Center" Margin="8 0 0 0"/>
								</StackPanel>
							</DataTemplate>
						</controls:AraComboBox.ItemTemplate>
					</controls:AraComboBox>
				</StackPanel>
			</StackPanel>
		</GroupBox>

		<GroupBox Grid.Row="4" Grid.ColumnSpan="3" Header="{DynamicResource Settings.Zone}" Style="{StaticResource AraGroupBox}">
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="40"/>
					<RowDefinition Height="16"/>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>

				<controls:AraButton Grid.Row="0" Style="{StaticResource SecondaryButton}" Command="{Binding SelectRegionCommand}">
					<controls:AraButton.Children>
						<Image Style="{StaticResource ButtonImage}" Source="/Assets/Icons/zone.png" />
						<TextBlock Text="{DynamicResource Settings.Zone.Button}" Margin="4 0 0 0"/>
					</controls:AraButton.Children>
				</controls:AraButton>
				<Grid Grid.Row="2">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*" />
						<ColumnDefinition Width="8" />
						<ColumnDefinition Width="*" />
						<ColumnDefinition Width="8" />
						<ColumnDefinition Width="*" />
						<ColumnDefinition Width="8" />
						<ColumnDefinition Width="*" />
					</Grid.ColumnDefinitions>

					<StackPanel Grid.Column="0">
						<Label Style="{StaticResource AraLabel}" Target="{Binding ElementName=X}" Content="{DynamicResource Settings.Zone.X}"/>
						<controls:AraTextBox 
								x:Name="X" 
								Text="{Binding CoordinatesX, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" 
								PlaceholderText="{DynamicResource Settings.Zone.X.Placeholder}" 
								Style="{StaticResource AraTextBox}" 
								InputType="{x:Static enums:TextBoxInputType.Number}"
								MaxLength="10"/>
					</StackPanel>
					<StackPanel Grid.Column="2">
						<Label Style="{StaticResource AraLabel}" Target="{Binding ElementName=Y}" Content="{DynamicResource Settings.Zone.Y}"/>
						<controls:AraTextBox 
								x:Name="Y" 
								Text="{Binding CoordinatesY, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" 
								PlaceholderText="{DynamicResource Settings.Zone.Y.Placeholder}" 
								Style="{StaticResource AraTextBox}" 
								InputType="{x:Static enums:TextBoxInputType.Number}"
								MaxLength="10"/>
					</StackPanel>
					<StackPanel Grid.Column="4">
						<Label Style="{StaticResource AraLabel}" Target="{Binding ElementName=ZoneWidth}" Content="{DynamicResource Settings.Zone.Width}"/>
						<controls:AraTextBox 
								x:Name="ZoneWidth" 
								Text="{Binding CoordinatesWidth, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" 
								PlaceholderText="{DynamicResource Settings.Zone.Width.Placeholder}" 
								Style="{StaticResource AraTextBox}" 
								InputType="{x:Static enums:TextBoxInputType.Number}" 
								MaxLength="10"/>
					</StackPanel>
					<StackPanel Grid.Column="6">
						<Label Style="{StaticResource AraLabel}" Target="{Binding ElementName=ZoneHeight}" Content="{DynamicResource Settings.Zone.Height}"/>
						<controls:AraTextBox 
								x:Name="ZoneHeight" 
								Text="{Binding CoordinatesHeight, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" 
								PlaceholderText="{DynamicResource Settings.Zone.Width.Placeholder}" 
								Style="{StaticResource AraTextBox}" 
								InputType="{x:Static enums:TextBoxInputType.Number}"
								MaxLength="10"/>
					</StackPanel>
				</Grid>
			</Grid>
		</GroupBox>

		<Grid Grid.Row="6" Grid.ColumnSpan="3">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto" />
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="Auto" />
			</Grid.ColumnDefinitions>

			<controls:AraButton Grid.Column="0" Command="{Binding OpenConfigFolderCommand}" Style="{StaticResource SecondarySmallButton}" HorizontalAlignment="Left">
				<controls:AraButton.Children>
					<TextBlock Text="{DynamicResource Settings.Button}" />
				</controls:AraButton.Children>
			</controls:AraButton>

			<controls:AraButton Grid.Column="2" Command="{Binding SaveSettingsCommand}" HorizontalAlignment="Right">
				<controls:AraButton.Style>
					<Style TargetType="controls:AraButton" BasedOn="{StaticResource PrimaryButton}">
						<Style.Triggers>
							<DataTrigger Binding="{Binding IsEdited}" Value="False">
								<Setter Property="IsEnabled" Value="False" />
							</DataTrigger>
						</Style.Triggers>
					</Style>
				</controls:AraButton.Style>
				<controls:AraButton.Children>
					<TextBlock Text="{DynamicResource General.Save}" />
				</controls:AraButton.Children>
			</controls:AraButton>
		</Grid>
	</Grid>
</UserControl>
