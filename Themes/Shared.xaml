<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:controls="clr-namespace:ARA.Controls.CustomControls"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<Style x:Key="PageTitle" TargetType="TextBlock">
		<Setter Property="Foreground" Value="{DynamicResource TextColorPrimary}" />
		<Setter Property="FontSize" Value="24" />
		<Setter Property="FontFamily" Value="{StaticResource Font-Primary}" />
		<Setter Property="VerticalAlignment" Value="Center" />
	</Style>

	<Style x:Key="PageTitleButton" TargetType="controls:AraButton">
		<Setter Property="Height" Value="32" />
		<Setter Property="Width" Value="32" />
		<Setter Property="CornerRadius" Value="{StaticResource Radius-2}" />
		<Setter Property="HoverBackground" Value="{DynamicResource PageTitleButton__HoverBackgroundColor}" />
		<Setter Property="Padding">
			<Setter.Value>
				<Thickness 
					Left="{StaticResource Spacing-1}"
					Right="{StaticResource Spacing-1}"
					Top="{StaticResource Spacing-0}"
					Bottom="{StaticResource Spacing-0}"/>
			</Setter.Value>
		</Setter>
	</Style>

	<Style x:Key="ButtonImage" TargetType="Image">
		<Setter Property="Height" Value="20" />
		<Setter Property="Width" Value="20" />
		<Setter Property="SnapsToDevicePixels" Value="True" />
	</Style>

	<Style x:Key="PrimaryButton" TargetType="controls:AraButton">
		<Setter Property="Foreground" Value="{DynamicResource TextColorSecondary}" />
		<Setter Property="HoverForeground" Value="{DynamicResource TextColorSecondary}" />
		<Setter Property="Background" Value="{DynamicResource PrimaryButton__BackgroundColor}" />
		<Setter Property="HoverBackground" Value="{DynamicResource PrimaryButton__HoverBackgroundColor}" />
		<Setter Property="CornerRadius" Value="{StaticResource Radius-1}" />
		<Setter Property="FontFamily" Value="{DynamicResource Font-Primary}" />
		<Setter Property="FontSize" Value="24" />
		<Setter Property="FontWeight" Value="Medium" />
		<Setter Property="Padding">
			<Setter.Value>
				<Thickness 
					Left="{StaticResource Spacing-2}"
					Right="{StaticResource Spacing-2}"
					Top="{StaticResource Spacing-1}"
					Bottom="{StaticResource Spacing-1}"/>
			</Setter.Value>
		</Setter>
	</Style>

	<Style x:Key="PrimarySmallButton" TargetType="controls:AraButton" BasedOn="{StaticResource PrimaryButton}">
		<Setter Property="FontSize" Value="16" />
	</Style>

	<Style x:Key="SecondaryButton" TargetType="controls:AraButton" BasedOn="{StaticResource PrimaryButton}">
		<Setter Property="Background" Value="{DynamicResource SecondaryButton__BackgroundColor}" />
		<Setter Property="HoverBackground" Value="{DynamicResource SecondaryButton__HoverBackgroundColor}" />
	</Style>

	<Style x:Key="SecondarySmallButton" TargetType="controls:AraButton" BasedOn="{StaticResource SecondaryButton}">
		<Setter Property="FontSize" Value="16" />
	</Style>

	<Style x:Key="AraComboBox" TargetType="controls:AraComboBox">
		<Setter Property="MinWidth" Value="200" />
		<Setter Property="ToggleButtonBackground" Value="{DynamicResource ToggleButtonBackground}" />
		<Setter Property="ToggleButtonBorderThickness" Value="2" />
		<Setter Property="ToggleButtonCornerRadius" Value="{StaticResource Radius-1}" />
		<Setter Property="ToggleButtonBorderBrush" Value="{DynamicResource ToggleButtonBorderBrush}" />
		<Setter Property="ToggleButtonArrowBrush" Value="{DynamicResource ToggleButtonArrowBrush}" />
		<Setter Property="ToggleButtonArrowHeight" Value="16" />
		<Setter Property="ToggleButtonArrowWidth" Value="16" />
		<Setter Property="ToggleButtonArrowMargin" >
			<Setter.Value>
				<Thickness 
				Left="{StaticResource Spacing-3}"
				Right="{StaticResource Spacing-3}"
				Top="{StaticResource Spacing-1}"
				Bottom="{StaticResource Spacing-1}"/>
			</Setter.Value>
		</Setter>
		<Setter Property="ToggleButtonHoverBackground" Value="{DynamicResource ToggleButtonHoverBackground}" />
		<Setter Property="ToggleButtonHoverBorderBrush" Value="{DynamicResource ToggleButtonHoverBorderBrush}" />
		<Setter Property="ToggleButtonHoverArrowBrush" Value="{DynamicResource ToggleButtonHoverArrowBrush}" />
		<Setter Property="ToggleButtonOpenBorderBrush" Value="{DynamicResource ToggleButtonOpenBorderBrush}" />
		<Setter Property="ToggleButtonOpenArrowBrush" Value="{DynamicResource ToggleButtonOpenArrowBrush}" />
		<Setter Property="ToggleButtonOpenBackground" Value="{DynamicResource ToggleButtonOpenBackground}" />
		<Setter Property="SelectedTextForeground" Value="{DynamicResource SelectedTextForeground}" />
		<Setter Property="SelectedTextFontSize" Value="20" />
		<Setter Property="SelectedTextFontFamily" Value="{StaticResource Font-Secondary}" />
		<Setter Property="SelectedTextFontWeight" Value="Medium" />
		<Setter Property="SelectedTextMargin">
			<Setter.Value>
				<Thickness 
				Left="{StaticResource Spacing-3}"
				Right="{StaticResource Spacing-3}"
				Top="{StaticResource Spacing-1}"
				Bottom="{StaticResource Spacing-1}"/>
			</Setter.Value>
		</Setter>
		<Setter Property="ItemsListCornerRadius" Value="{StaticResource Radius-1}" />
		<Setter Property="ItemsListMaxHeight" Value="124" />
		<Setter Property="ItemsListBorderBrush" Value="{DynamicResource ItemsListBorderBrush}" />
		<Setter Property="ItemsListBorderThickness" Value="2" />
		<Setter Property="ListItemHeight" Value="40" />
		<Setter Property="ListItemForeground" Value="{DynamicResource ListItemForeground}" />
		<Setter Property="ListItemBackground" Value="{DynamicResource ListItemBackground}" />
		<Setter Property="ListItemMargin">
			<Setter.Value>
				<Thickness 
				Left="{StaticResource Spacing-3}"
				Right="{StaticResource Spacing-3}"
				Top="{StaticResource Spacing-1}"
				Bottom="{StaticResource Spacing-1}"/>
			</Setter.Value>
		</Setter>
		<Setter Property="ListItemFontSize" Value="20" />
		<Setter Property="ListItemFontWeight" Value="Medium" />
		<Setter Property="ListItemFontFamily" Value="{StaticResource Font-Secondary}" />
		<Setter Property="ListItemHoverBackground" Value="{DynamicResource ListItemHoverBackground}" />
		<Setter Property="ListItemSelectedBackground" Value="{DynamicResource ListItemSelectedBackground}" />
		<Setter Property="PlaceholderForeground" Value="{DynamicResource PlaceholderTextForeground}" />
		<Setter Property="TextBoxMargin">
			<Setter.Value>
				<Thickness 
					Left="{StaticResource Spacing-3}"
					Right="{StaticResource Spacing-7}"
					Top="{StaticResource Spacing-0}"
					Bottom="{StaticResource Spacing-0}"/>
			</Setter.Value>
		</Setter>
	</Style>

	<Style x:Key="AraTextBox" TargetType="controls:AraTextBox">
		<Setter Property="Height" Value="40" />
		<Setter Property="FontSize" Value="20" />
		<Setter Property="BorderThickness" Value="2" />
		<Setter Property="BorderBrush" Value="Transparent" />
		<Setter Property="HoverBorderBrush" Value="{DynamicResource TextBox__HoverBorderBrush}" />
		<Setter Property="FontFamily" Value="{StaticResource Font-Secondary}" />
		<Setter Property="FontWeight" Value="Medium" />
		<Setter Property="Foreground" Value="{DynamicResource TextColorSecondary}" />
		<Setter Property="Background" Value="{DynamicResource TextBox__Background}" />
		<Setter Property="CornerRadius" Value="{StaticResource Radius-1}" />
		<Setter Property="VerticalContentAlignment" Value="Center" />
		<Setter Property="PlaceholderForeground" Value="{DynamicResource PlaceholderTextForeground}" />
		<Setter Property="ErrorBorderBrush" Value="{DynamicResource TextBox__ErrorBorderBrsuh}" />
		<Setter Property="Padding">
			<Setter.Value>
				<Thickness 
					Left="{StaticResource Spacing-2}"
					Top="{StaticResource Spacing-0}"
					Right="{StaticResource Spacing-2}"
					Bottom="{StaticResource Spacing-0}" />
			</Setter.Value>
		</Setter>
	</Style>

	<Style x:Key="AraLabel" TargetType="Label">
		<Setter Property="FontSize" Value="18" />
		<Setter Property="FontFamily" Value="{StaticResource Font-Secondary}" />
		<Setter Property="Foreground" Value="{DynamicResource TextColorPrimary}" />
		<Setter Property="Padding">
			<Setter.Value>
				<Thickness 
					Left="{StaticResource Spacing-0}"
					Top="{StaticResource Spacing-0}"
					Right="{StaticResource Spacing-0}"
					Bottom="{StaticResource Spacing-1}" />
			</Setter.Value>
		</Setter>
	</Style>

	<Style x:Key="AraGroupBox" TargetType="GroupBox">
		<Setter Property="FontSize" Value="18" />
		<Setter Property="FontFamily" Value="{StaticResource Font-Secondary}" />
		<Setter Property="Foreground" Value="{DynamicResource TextColorPrimary}" />
		<Setter Property="Padding">
			<Setter.Value>
				<Thickness 
					Left="{StaticResource Spacing-3}"
					Top="{StaticResource Spacing-3}"
					Right="{StaticResource Spacing-3}"
					Bottom="{StaticResource Spacing-3}" />
			</Setter.Value>
		</Setter>
	</Style>

	<Style x:Key="AraStackRow" TargetType="StackPanel">
		<Setter Property="Margin">
			<Setter.Value>
				<Thickness 
					Left="{StaticResource Spacing-0}"
					Top="{StaticResource Spacing-1}"
					Right="{StaticResource Spacing-0}"
					Bottom="{StaticResource Spacing-1}" />
			</Setter.Value>
		</Setter>
	</Style>

	<Style x:Key="AraTextBlock" TargetType="TextBlock">
		<Setter Property="FontFamily" Value="{StaticResource Font-Secondary}" />
		<Setter Property="FontSize" Value="18" />
		<Setter Property="FontWeight" Value="Normal" />
		<Setter Property="Foreground" Value="{DynamicResource TextColorPrimary}" />
	</Style>

	<Style x:Key="AraStackRowLabel" TargetType="TextBlock" BasedOn="{StaticResource AraTextBlock}">
		<Setter Property="MinWidth" Value="100" />
		<Setter Property="VerticalAlignment" Value="Center" />
	</Style>

	<Style x:Key="AraHyperlink" TargetType="Hyperlink">
		<Setter Property="Foreground" Value="{DynamicResource Hyperlink__Foreground}" />
		<Style.Triggers>
			<Trigger Property="IsMouseOver" Value="True">
				<Setter Property="Foreground" Value="{DynamicResource Hyperlink__HoverForeground}" />
			</Trigger>
		</Style.Triggers>
	</Style>
</ResourceDictionary>